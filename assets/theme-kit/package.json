{
  "name": "portrait-talk-theme-kit",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "node scripts/generate-theme-assets.mjs",
    "check:generated": "node scripts/generate-theme-assets.mjs --check",
    "check": "npm run check:generated && node scripts/check-contrast.mjs && node scripts/check-geometry.mjs",
    "serve": "python3 -m http.server 8000",
    "render:backgrounds": "python3 scripts/render-backgrounds.py"
  }
}
