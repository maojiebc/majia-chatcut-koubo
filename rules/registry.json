      "enforcement": {
        "level": "runtime",
        "checkId": "caption.automatic-wrap",
        "implementedBy": [
          "scripts/validate-caption-pages.mjs",
          "tests/caption-validator.test.mjs"
        ]
      },
      "fixtureRefs": {
