{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/maojiebc/majia-chatcut-koubo/schemas/creator-os-common.schema.json",
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)+$"
    },
    "revision": {
      "type": "string",
      "pattern": "^rev_[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    },
    "rate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "numerator",
        "denominator"
      ],
      "properties": {
        "numerator": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "denominator": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        }
      }
    },
    "timeRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "rate",
        "start",
        "end"
      ],
      "properties": {
        "domain": {
          "enum": [
            "source",
            "timeline",
            "graphics",
            "export"
          ]
        },
        "rate": {
          "$ref": "#/$defs/rate"
        },
        "start": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "end": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "status"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "not-required",
            "pending",
            "approved",
            "rejected"
          ]
        },
        "approvalId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^approval_[a-z0-9]+(?:_[a-z0-9]+)*$"
        }
      }
    }
  }
}
