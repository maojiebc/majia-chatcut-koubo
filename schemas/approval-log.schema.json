{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/maojiebc/majia-chatcut-koubo/schemas/approval-log.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "projectId",
    "events"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0"
    },
    "projectId": {
      "$ref": "creator-os-common.schema.json#/$defs/identifier"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "eventId",
          "approvalId",
          "previewBundleId",
          "actorId",
          "decision",
          "recordedAt",
          "scope",
          "invalidatesOn"
        ],
        "properties": {
          "eventId": {
            "$ref": "creator-os-common.schema.json#/$defs/identifier"
          },
          "approvalId": {
            "type": "string",
            "pattern": "^approval_[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "previewBundleId": {
            "$ref": "creator-os-common.schema.json#/$defs/identifier"
          },
          "actorId": {
            "$ref": "creator-os-common.schema.json#/$defs/identifier"
          },
          "decision": {
            "enum": [
              "approved",
              "rejected",
              "revoked"
            ]
          },
          "recordedAt": {
            "type": "string",
            "format": "date-time"
          },
          "scope": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "projectId",
              "runId",
              "timelineId",
              "timelineRevision",
              "planHash",
              "styleFingerprint",
              "windowIds"
            ],
            "properties": {
              "projectId": {
                "$ref": "creator-os-common.schema.json#/$defs/identifier"
              },
              "runId": {
                "$ref": "creator-os-common.schema.json#/$defs/identifier"
              },
              "timelineId": {
                "$ref": "creator-os-common.schema.json#/$defs/identifier"
              },
              "timelineRevision": {
                "$ref": "creator-os-common.schema.json#/$defs/revision"
              },
              "planHash": {
                "$ref": "creator-os-common.schema.json#/$defs/sha256"
              },
              "styleFingerprint": {
                "$ref": "creator-os-common.schema.json#/$defs/sha256"
              },
              "windowIds": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "$ref": "creator-os-common.schema.json#/$defs/identifier"
                }
              }
            }
          },
          "invalidatesOn": {
            "type": "array",
            "minItems": 4,
            "uniqueItems": true,
            "items": {
              "enum": [
                "planHash",
                "styleFingerprint",
                "timelineRevision",
                "previewBundleId"
              ]
            }
          }
        }
      }
    }
  }
}
