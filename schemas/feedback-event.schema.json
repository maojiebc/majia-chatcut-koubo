{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/maojiebc/majia-chatcut-koubo/schemas/feedback-event.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "eventId",
    "eventRefHash",
    "projectRefHash",
    "runRefHash",
    "eventType",
    "occurredAt",
    "metrics",
    "ruleRefs",
    "redaction"
  ],
  "properties": {
    "$schema": {
      "const": "https://github.com/maojiebc/majia-chatcut-koubo/schemas/feedback-event.schema.json"
    },
    "schemaVersion": {
      "const": "1.0.0"
    },
    "eventId": {
      "$ref": "creator-os-common.schema.json#/$defs/identifier"
    },
    "eventRefHash": {
      "$ref": "creator-os-common.schema.json#/$defs/sha256"
    },
    "projectRefHash": {
      "$ref": "creator-os-common.schema.json#/$defs/sha256"
    },
    "runRefHash": {
      "$ref": "creator-os-common.schema.json#/$defs/sha256"
    },
    "eventType": {
      "enum": [
        "preview",
        "rework",
        "recovery",
        "failure",
        "caption",
        "privacy",
        "asset-reuse",
        "delivery"
      ]
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "failureSignature": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:_[A-Z0-9]+)+$"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "attemptCount": {
          "type": "integer",
          "minimum": 0
        },
        "findingCount": {
          "type": "integer",
          "minimum": 0
        },
        "recoveryCount": {
          "type": "integer",
          "minimum": 0
        },
        "accepted": {
          "type": "boolean"
        },
        "success": {
          "type": "boolean"
        }
      }
    },
    "ruleRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+){2,}$"
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "externalSharing"
      ],
      "properties": {
        "status": {
          "const": "content-free"
        },
        "externalSharing": {
          "const": "not-authorized"
        }
      }
    }
  }
}
