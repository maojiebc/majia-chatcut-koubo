{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/maojiebc/majia-chatcut-koubo/schemas/execution-plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "projectId",
    "runId",
    "timelineId",
    "timelineRevision",
    "planHash",
    "operations"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0"
    },
    "projectId": {
      "$ref": "creator-os-common.schema.json#/$defs/identifier"
    },
    "runId": {
      "$ref": "creator-os-common.schema.json#/$defs/identifier"
    },
    "timelineId": {
      "$ref": "creator-os-common.schema.json#/$defs/identifier"
    },
    "timelineRevision": {
      "$ref": "creator-os-common.schema.json#/$defs/revision"
    },
    "planHash": {
      "$ref": "creator-os-common.schema.json#/$defs/sha256"
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "operationId",
          "sceneId",
          "idempotencyKey",
          "logicalId",
          "action",
          "desiredHash",
          "desiredState"
        ],
        "properties": {
          "operationId": {
            "$ref": "creator-os-common.schema.json#/$defs/identifier"
          },
          "sceneId": {
            "$ref": "creator-os-common.schema.json#/$defs/identifier"
          },
          "idempotencyKey": {
            "$ref": "creator-os-common.schema.json#/$defs/sha256"
          },
          "logicalId": {
            "$ref": "creator-os-common.schema.json#/$defs/identifier"
          },
          "action": {
            "const": "upsert"
          },
          "desiredHash": {
            "$ref": "creator-os-common.schema.json#/$defs/sha256"
          },
          "desiredState": {
            "type": "object",
            "minProperties": 1
          }
        }
      }
    }
  }
}
