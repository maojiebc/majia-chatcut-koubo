{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/maojiebc/majia-chatcut-koubo/schemas/owner-ledger.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "projectId",
    "timelineId",
    "timelineRevision",
    "owners"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0"
    },
    "projectId": {
      "$ref": "creator-os-common.schema.json#/$defs/identifier"
    },
    "timelineId": {
      "$ref": "creator-os-common.schema.json#/$defs/identifier"
    },
    "timelineRevision": {
      "$ref": "creator-os-common.schema.json#/$defs/revision"
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ownerId",
          "domain",
          "range",
          "subjectRef"
        ],
        "properties": {
          "ownerId": {
            "$ref": "creator-os-common.schema.json#/$defs/identifier"
          },
          "domain": {
            "enum": [
              "visual-composition",
              "privacy",
              "caption",
              "audio",
              "graphics"
            ]
          },
          "range": {
            "$ref": "creator-os-common.schema.json#/$defs/timeRange"
          },
          "subjectRef": {
            "$ref": "creator-os-common.schema.json#/$defs/identifier"
          }
        }
      }
    }
  }
}
