{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/maojiebc/majia-chatcut-koubo/schemas/terminology.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "maintainer", "entries", "shortCardWhitelist"],
  "properties": {
    "$schema": {"type": "string"},
    "$comment": {"type": "string"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "maintainer": {"type": "string", "minLength": 1},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["correct", "wrong", "matchMode"],
        "properties": {
          "correct": {"type": "string", "minLength": 1},
          "wrong": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "matchMode": {"enum": ["substring", "exact"]},
          "caseSensitive": {"type": "boolean"},
          "requiresAudioEvidence": {"type": "boolean"},
          "risk": {"enum": ["number", "amount", "percentage", "date", "negation", "directional-term", "proper-noun"]}
        }
      }
    },
    "shortCardWhitelist": {
      "type": "object",
      "required": ["approved"],
      "properties": {
        "$comment": {"type": "string"},
        "approved": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 2}}
      }
    }
  }
}
