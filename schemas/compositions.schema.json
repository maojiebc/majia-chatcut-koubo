{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/maojiebc/majia-chatcut-koubo/schemas/compositions.schema.json",
  "title": "Dual-source composition registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "sourceSlots", "formats"],
  "properties": {
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "sourceSlots": {
      "type": "array",
      "minItems": 2,
      "items": {"$ref": "#/$defs/sourceSlot"}
    },
    "formats": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/format"}
    }
  },
  "$defs": {
    "nonEmptyStringArray": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "sourceSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "role", "defaultFit", "mustRemainVisible", "mustBeRedacted"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "label": {"type": "string", "minLength": 1},
        "role": {"type": "string", "minLength": 1},
        "defaultFit": {"enum": ["contain", "cover"]},
        "mustRemainVisible": {"$ref": "#/$defs/nonEmptyStringArray"},
        "mustBeRedacted": {"$ref": "#/$defs/nonEmptyStringArray"}
      }
    },
    "rect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": {"type": "number", "minimum": 0},
        "y": {"type": "number", "minimum": 0},
        "w": {"type": "number", "exclusiveMinimum": 0},
        "h": {"type": "number", "exclusiveMinimum": 0},
        "radius": {"type": "number", "minimum": 0}
      }
    },
    "subtitleRect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "w", "h", "fontSize", "maxLines"],
      "properties": {
        "x": {"type": "number", "minimum": 0},
        "y": {"type": "number", "minimum": 0},
        "w": {"type": "number", "exclusiveMinimum": 0},
        "h": {"type": "number", "exclusiveMinimum": 0},
        "radius": {"type": "number", "minimum": 0},
        "fontSize": {"type": "number", "exclusiveMinimum": 0},
        "maxLines": {"const": 1}
      }
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "ratio", "fps"],
      "properties": {
        "width": {"type": "integer", "exclusiveMinimum": 0},
        "height": {"type": "integer", "exclusiveMinimum": 0},
        "ratio": {"enum": ["16:9", "9:16"]},
        "fps": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "safeArea": {
      "type": "object",
      "additionalProperties": false,
      "required": ["left", "right", "top", "bottom"],
      "properties": {
        "left": {"type": "number", "minimum": 0},
        "right": {"type": "number", "minimum": 0},
        "top": {"type": "number", "minimum": 0},
        "bottom": {"type": "number", "minimum": 0}
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description",
        "layoutVersion",
        "screenFit",
        "speakerShape",
        "screen",
        "speaker",
        "title",
        "point",
        "subtitle"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "layoutVersion": {"type": "integer", "minimum": 1},
        "screenFit": {"enum": ["contain", "cover"]},
        "speakerShape": {"enum": ["circle", "rounded", "cutout"]},
        "screen": {"$ref": "#/$defs/rect"},
        "speaker": {"$ref": "#/$defs/rect"},
        "title": {"$ref": "#/$defs/rect"},
        "point": {"$ref": "#/$defs/rect"},
        "subtitle": {"$ref": "#/$defs/subtitleRect"}
      }
    },
    "format": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "shortName",
        "description",
        "canvas",
        "safeArea",
        "subtitleBaseline",
        "layouts"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "name": {"type": "string", "minLength": 1},
        "shortName": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "canvas": {"$ref": "#/$defs/canvas"},
        "safeArea": {"$ref": "#/$defs/safeArea"},
        "subtitleBaseline": {"$ref": "#/$defs/subtitleRect"},
        "layouts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/layout"}
        }
      }
    }
  }
}
