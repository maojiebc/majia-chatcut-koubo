{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/maojiebc/majia-chatcut-koubo/schemas/captions.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "metadata", "pages"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceVariant", "timelineFps", "automaticWrapAllowed", "pagination"],
      "properties": {
        "sourceVariant": {"const": "original"},
        "timelineFps": {"type": "number", "exclusiveMinimum": 0},
        "automaticWrapAllowed": {"const": false},
        "pagination": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxLines", "maxCharactersPerLine"],
          "properties": {
            "maxLines": {"const": 1},
            "maxCharactersPerLine": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "startFrame", "endFrame", "text", "lines", "words"],
        "properties": {
          "index": {"type": "integer", "minimum": 1},
          "startFrame": {"type": "integer", "minimum": 0},
          "endFrame": {"type": "integer", "minimum": 1},
          "text": {"type": "string", "minLength": 1},
          "lines": {"const": 1},
          "words": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["key", "text", "startFrame", "endFrame"],
              "properties": {
                "key": {"type": "string", "minLength": 1},
                "text": {"type": "string", "minLength": 1},
                "startFrame": {"type": "integer", "minimum": 0},
                "endFrame": {"type": "integer", "minimum": 1},
                "edited": {"type": "boolean"}
              }
            }
          }
        }
      }
    }
  }
}
