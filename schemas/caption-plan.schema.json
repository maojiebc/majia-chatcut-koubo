{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/maojiebc/majia-chatcut-koubo/schemas/caption-plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "projectId",
    "timelineId",
    "timelineRevision",
    "transcriptId",
    "transcriptRevision",
    "pages"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0"
    },
    "projectId": {
      "$ref": "creator-os-common.schema.json#/$defs/identifier"
    },
    "timelineId": {
      "$ref": "creator-os-common.schema.json#/$defs/identifier"
    },
    "timelineRevision": {
      "$ref": "creator-os-common.schema.json#/$defs/revision"
    },
    "transcriptId": {
      "$ref": "creator-os-common.schema.json#/$defs/identifier"
    },
    "transcriptRevision": {
      "$ref": "creator-os-common.schema.json#/$defs/sha256"
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pageId",
          "range",
          "sourceWordIds",
          "sourceText",
          "displayText",
          "lineCount",
          "status",
          "evidenceRefs"
        ],
        "properties": {
          "pageId": {
            "$ref": "creator-os-common.schema.json#/$defs/identifier"
          },
          "range": {
            "$ref": "creator-os-common.schema.json#/$defs/timeRange"
          },
          "sourceWordIds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "creator-os-common.schema.json#/$defs/identifier"
            }
          },
          "sourceText": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^\\r\\n]+$"
          },
          "displayText": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^\\r\\n]+$"
          },
          "lineCount": {
            "const": 1
          },
          "status": {
            "enum": [
              "planned",
              "verified"
            ]
          },
          "evidenceRefs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "creator-os-common.schema.json#/$defs/identifier"
            }
          }
        }
      }
    }
  }
}
