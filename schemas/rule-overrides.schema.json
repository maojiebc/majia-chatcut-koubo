{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/maojiebc/majia-chatcut-koubo/schemas/rule-overrides.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "registryVersion",
    "overrides"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "registryVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "overrides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ruleId",
          "value"
        ],
        "properties": {
          "ruleId": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+){2,}$"
          },
          "value": {
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "number"
              },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            ]
          }
        }
      }
    }
  }
}
