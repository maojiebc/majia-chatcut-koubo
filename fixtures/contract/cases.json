{
  "$comment": "Contract fixtures are validated as part of the repository scan. Negative cases pass only when they fail for the declared signatures.",
  "version": 1,
  "cases": [
    {
      "path": "fixtures/contract/positive/captions.valid.json",
      "schema": "schemas/captions.schema.json",
      "expect": "valid"
    },
    {
      "path": "fixtures/contract/negative/captions.multiline.invalid.json",
      "schema": "schemas/captions.schema.json",
      "expect": "invalid",
      "expectedErrorSignatures": [
        "const@/pages/0/lines"
      ]
    },
    {
      "path": "fixtures/contract/negative/captions.linebreak.invalid.json",
      "schema": "schemas/captions.schema.json",
      "expect": "invalid",
      "expectedErrorSignatures": [
        "pattern@/pages/0/text"
      ]
    },
    {
      "path": "fixtures/contract/negative/compatibility.invalid-hash.invalid.json",
      "schema": "schemas/compatibility.schema.json",
      "expect": "invalid",
      "expectedErrorSignatures": [
        "pattern@/toolSchemaHash",
        "if@/"
      ]
    },
    {
      "path": "fixtures/contract/negative/compatibility.validated-without-evidence.invalid.json",
      "schema": "schemas/compatibility.schema.json",
      "expect": "invalid",
      "expectedErrorSignatures": [
        "pattern@/requiredProbes/0/evidence",
        "if@/"
      ]
    }
  ]
}
