{
  "$schema": "../schemas/profile.schema.json",
  "$comment": "复制后填写并在样片上验证。只有 status=validated 且记录了验证时间线，才能通过发布门禁。",
  "schemaVersion": "2.0.0",
  "policyVersion": "1.0.0",
  "profileId": "your-name-landscape-default",
  "profileVersion": "1.0.0",
  "status": "untested-template",
  "provenance": {
    "projectId": "REPLACE-with-your-project-id",
    "validatedTimelineIds": [],
    "note": "记录这组数字在哪条时间线上验证过；换素材、画幅或宿主版本须重新标定"
  },
  "timeline": {
    "width": 1920,
    "height": 1080,
    "fps": 30
  },
  "captions": {
    "sourceVariant": "original",
    "font": "Smiley Sans, PingFang SC, sans-serif",
    "sizePx": 42,
    "weight": 700,
    "color": "#0B5F58",
    "backgroundColor": "#F7FFFD",
    "backgroundOpacity": 1,
    "backgroundRadius": 18,
    "displayMode": "single",
    "maxCharactersPerLine": 22,
    "layout": {"left": 180, "top": 924, "width": 1560, "height": 48},
    "displayOverridePolicy": {"maxReplacementCharacters": 4}
  },
  "presenterWindow": {
    "$comment": "人脸取景基线从 compositions.json 取；magnification 是素材上的实测值。",
    "circleDiameterPx": 330,
    "magnificationBaseline": 0.3,
    "compositionNotes": "完整头发、额头呼吸位、颈肩和部分上半身；居中不等于贴脸"
  },
  "audio": {
    "anchorGainDb": 2,
    "duplicateTrackMode": "mute",
    "clickGuardFadeOutSeconds": 0.06,
    "firstAudibleCheck": "第 0 帧起可听，导出音频实听开头 2 秒"
  },
  "terminologyFile": "terminology.template.json"
}
